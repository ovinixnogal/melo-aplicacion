rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true; 
    }

    // --- RULES ---

    // Users Collection: Everyone can see their own, only they can edit profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Prevent creating accounts with admin privileges directly
      allow create: if isSignedIn() 
        && (!("isAdmin" in request.resource.data) || request.resource.data.isAdmin == false);
        
      // Prevent privilege escalation and subscription tampering on updates
      allow update: if isAdmin() || (
        isOwner(userId) 
        && (!("isAdmin" in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin)
        && (!("banned" in request.resource.data) || request.resource.data.banned == resource.data.banned)
        && (!("subscription" in request.resource.data) || request.resource.data.subscription == resource.data.subscription)
        && (!("subscriptionHistory" in request.resource.data) || request.resource.data.subscriptionHistory == resource.data.subscriptionHistory)
      );
      
      allow delete: if isAdmin();
    }

    // Clients Collection: User-owned
    match /clients/{clientId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Loans and sub-collections (installments)
    match /loans/{loanId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && (!("amount" in request.resource.data) || (request.resource.data.amount is number && request.resource.data.amount > 0));
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /installments/{instId} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/loans/$(loanId)).data.userId) || isAdmin();
      }
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && (!("amount" in request.resource.data) || (request.resource.data.amount is number && request.resource.data.amount > 0));
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Capital History
    match /capital_history/{histId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Subscription Payments
    match /subscription_payments/{payId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Exchange Rates: Public Read, Admin Write
    match /exchange_rates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications: users can only manage their own notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
