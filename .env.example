# Copia este archivo como .env y completa los valores
# NUNCA comitear el archivo .env real

# Obligatorio en producción, recomendado en desarrollo
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
MELO_SECRET_KEY=

# Base de datos (dejar vacío para SQLite local)
DATABASE_URL=

# Redis para rate limiting (dejar vacío para usar memoria)
REDIS_URL=

# S3 / Supabase para almacenamiento de archivos (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# WebAuthn (RP_ID es tu dominio sin https://)
RP_ID=localhost

# Push notifications (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
